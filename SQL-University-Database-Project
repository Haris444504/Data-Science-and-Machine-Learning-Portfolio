## 🔍 SQL Concepts Covered

### ✅ Basic Filtering & Sorting
```sql
-- Students with CGPA above 3.5
SELECT * FROM Student WHERE student_cgpa > 3.5;

-- Teachers who specialize in Networks
SELECT * FROM Teacher WHERE specialization = 'Networks';

-- Students sorted by CGPA (highest first)
SELECT * FROM Student ORDER BY student_cgpa DESC;
```

### ✅ Aggregate Functions
```sql
SELECT COUNT(*)           FROM Student;   -- Total students
SELECT AVG(student_cgpa)  FROM Student;   -- Average CGPA
SELECT MAX(student_cgpa)  FROM Student;   -- Highest CGPA
```

### ✅ JOINs
```sql
-- Teachers with their department names
SELECT teacher_name, dep_Name
FROM Department
LEFT JOIN Teacher ON Department.dep_ID = Teacher.dep_ID;

-- Students with enrolled courses and grades
SELECT student_name, course_name, grade
FROM Student
LEFT JOIN Enrollment ON Student.student_id = Enrollment.student_id
JOIN Courses ON Enrollment.course_ID = Courses.course_ID;

-- Student count per department
SELECT dep_Name, COUNT(*)
FROM Student
JOIN Department ON Student.dep_ID = Department.dep_ID
GROUP BY dep_Name;
```

### ✅ Subqueries
```sql
-- Students with above-average CGPA
SELECT * FROM Student
WHERE student_cgpa > (SELECT AVG(student_cgpa) FROM Student);

-- Student with the highest CGPA
SELECT * FROM Student
WHERE student_cgpa = (SELECT MAX(student_cgpa) FROM Student);
```

### ✅ Views
```sql
-- Reusable student report view
CREATE VIEW Student_Report AS
SELECT s.student_id, s.student_name, d.dep_Name, s.student_cgpa
FROM Student s
JOIN Department d ON s.dep_ID = d.dep_ID;

SELECT * FROM Student_Report;
```

### ✅ LIMIT
```sql
-- Top student by CGPA
SELECT * FROM Student ORDER BY student_cgpa DESC LIMIT 1;
```

