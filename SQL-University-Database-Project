-- Student Table

CREATE TABLE Student(
    student_id INT PRIMARY KEY,
    student_name VARCHAR(50) NOT NULL,
    student_email VARCHAR(50) UNIQUE,
    semester INT,
    student_cgpa FLOAT,
    dep_ID INT,
    FOREIGN KEY (dep_ID) REFERENCES Department(dep_ID)
);

